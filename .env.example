# DishDollar Environment Variables
# Copy this file to .env.local and fill in your values

# ===================
# Supabase Configuration
# ===================
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===================
# Instacart Integration (Optional)
# ===================
# Apply for API access at: https://www.instacart.com/company/business/developers
# Used for: shoppable recipe pages, nearby retailers, affiliate links
VITE_INSTACART_API_KEY=your-instacart-api-key-here

# ===================
# Google OAuth (Optional)
# ===================
# Configure in Supabase Dashboard > Authentication > Providers > Google
# No frontend env var needed - configured in Supabase
