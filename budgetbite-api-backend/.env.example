# Kroger API Credentials
KROGER_CLIENT_ID=your_kroger_client_id
KROGER_CLIENT_SECRET=your_kroger_client_secret

# Instacart API Configuration
# Development: https://connect.dev.instacart.tools
# Production:  https://connect.instacart.com
INSTACART_API_URL=https://connect.dev.instacart.tools
INSTACART_API_KEY=your_instacart_api_key

# Spoonacular API (Ingredient cost estimation for non-Kroger stores)
# Free tier: 150 points/day - Get key at: https://spoonacular.com/food-api/console
SPOONACULAR_API_KEY=your_spoonacular_api_key

# Supabase Configuration (for caching Instacart URLs and ingredient prices)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Google Custom Search API (Layer 1 - Recipe Discovery)
GOOGLE_CUSTOM_SEARCH_API_KEY=your_google_cse_api_key
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# Firecrawl API (Layer 2 - Recipe Extraction)
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Anthropic API (Layer 3 - AI Normalization)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Port (Heroku sets this automatically)
PORT=3000

# Set to 'true' to log API requests without calling external APIs
DRY_RUN=false
