# Kroger API Credentials
KROGER_CLIENT_ID=your_kroger_client_id
KROGER_CLIENT_SECRET=your_kroger_client_secret

# Instacart API Configuration
# Development: https://connect.dev.instacart.tools
# Production:  https://connect.instacart.com
INSTACART_API_URL=https://connect.dev.instacart.tools
INSTACART_API_KEY=your_instacart_api_key

# Supabase Configuration (for caching Instacart URLs)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Port (Heroku sets this automatically)
PORT=3000

# Set to 'true' to log API requests without calling external APIs
DRY_RUN=false
